        <Cell ss:Formula="=AVERAGE(B2:B11)"><Data ss:Type="Number">67.3</Data></Cell>
        <Cell ss:Formula="=STDEV.S(B2:B11)"><Data ss:Type="Number">54.9</Data></Cell>
        <Cell ss:Formula="=MAX(0,AVERAGE(B2:B11)-T.INV.2T(0.05,COUNT(B2:B11)-1)*STDEV.S(B2:B11)/SQRT(COUNT(B2:B11)))"><Data ss:Type="Number">28.0</Data></Cell>
